# In production on Railway: set VITE_API_URL=/api (same server, relative path)
# In local dev: set to your local server
VITE_API_URL=http://localhost:5000/api

# Only needed in local dev (for logo image URLs that aren't on Cloudinary yet)
# In production: leave empty (Cloudinary URLs are absolute)
VITE_API_BASE=http://localhost:5000
